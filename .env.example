# App
APP_TIMEZONE=Asia/Riyadh

# Binance Live API
BINANCE_API_KEY=
BINANCE_API_SECRET=
LIVE_ENTRY_LIMIT_BUFFER_PCT=0.03
LIVE_ENTRY_LIMIT_FALLBACK_MARKET=true

# Database
DATABASE_URL=sqlite:////data/paper_trading.db

# Engine
CYCLE_SECONDS=3
FAST_LOOP_SECONDS=30
MEDIUM_REFRESH_SECONDS=300
SLOW_RECALC_SECONDS=14400
PAPER_START_BALANCE=10000
ENFORCE_BTC_FILTER=true

# Smart DCA settings
DCA_NEAR_SUPPORT_PCT=2.0
DCA_SUPPORT_SCORE_THRESHOLD=70
DCA_RSI_OVERSOLD=35
DCA_REVERSAL_MIN_CONDITIONS=2
DCA_MAX_SYMBOL_ALLOCATION_X=7.0
DCA_SCALE_1=1.5
DCA_SCALE_2=2.0
DCA_SCALE_3=3.0
DCA_SCALE_4=3.5
DCA_SCALE_5=4.5
